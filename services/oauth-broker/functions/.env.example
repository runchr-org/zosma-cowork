# Public Web-application OAuth client id for THIS deployment's environment.
# This is NOT a secret (the client_id is public). The matching client SECRET is
# stored in Google Secret Manager as GOOGLE_OAUTH_CLIENT_SECRET — never here.
#
# Copy to `.env` (gitignored) and set the value for the env you're deploying.
#
# Staging ("Zosma Cowork Staging"):
GOOGLE_OAUTH_CLIENT_ID=830231223031-pukjd742a01uau7oekvrs231fb737eo0.apps.googleusercontent.com

# Optional: deploy region (default us-central1)
# BROKER_REGION=us-central1
